{
  "version": 2,
  "framework": "vite",
  "build": {
    "env": {
      "NITRO_PRESET": "vercel"
    }
  },
  "routes": [
    {
      "src": "/_vercel/insights/(.*)",
      "dest": "/_vercel/insights/$1"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/.output/public/assets/$1",
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "/(.*)",
      "dest": "/.output/server/index.mjs"
    }
  ]
}

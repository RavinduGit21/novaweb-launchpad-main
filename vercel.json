{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/assets/(.*)", "destination": "/dist/client/assets/$1" },
    { "source": "/portfolio/(.*)", "destination": "/dist/client/portfolio/$1" },
    { "source": "/premium_mockup.png", "destination": "/dist/client/premium_mockup.png" },
    { "source": "/(.*)", "destination": "/api/index.js" }
  ]
}
